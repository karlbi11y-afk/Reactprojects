# Server port. Railway sets this automatically in production.
PORT=5000

# Allowed frontend origin(s) for CORS.
# Use a comma-separated list if you need multiple domains.
FRONTEND_URL=http://localhost:5174

# Public base URL to the tattoo-crm backend that inkrevenue forwards API calls to.
CRM_API_BASE_URL=http://localhost:4000

# Optional rate limit tuning for public form submissions.
SUBMISSION_RATE_LIMIT_WINDOW_MS=900000
SUBMISSION_RATE_LIMIT_MAX=6

# Optional rate limit tuning for draft saves.
DRAFT_SAVE_RATE_LIMIT_WINDOW_MS=900000
DRAFT_SAVE_RATE_LIMIT_MAX=40

# Optional rate limit tuning for public read endpoints.
PUBLIC_READ_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_READ_RATE_LIMIT_MAX=20
